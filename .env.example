# ─────────────────────────────────────────────────────────────────────────────
# AI Agent — Environment Variables Template
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NOT be committed.
#
# To load on Windows (Command Prompt):
#   for /f "delims== tokens=1,2" %i in (.env) do set %i=%j
#
# To load on Windows (PowerShell):
#   Get-Content .env | ForEach-Object { $k,$v = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($k,$v) }
#
# To load on Linux / Mac:
#   export $(grep -v '^#' .env | xargs)
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the internally hosted OpenAI-compatible LLM server.
# Example: http://llm.bank.local:8080
# Leave as-is to fall back to OpenAI cloud.
LLM_BASE_URL=http://your-internal-llm-host:port

# API key for the LLM endpoint.
# Set to "none" if the internal server does not require authentication.
LLM_API_KEY=your-api-key-here

# Model name as configured on the internal LLM server.
# Examples: llama3, mistral-7b, gpt-4o, qwen2
LLM_MODEL=gpt-4o
