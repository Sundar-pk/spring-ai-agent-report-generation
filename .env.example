# ─────────────────────────────────────────────────────────────────────────────
# AI Agent — Environment Variables Template
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NOT be committed.
#
# To load on Windows (Command Prompt):
#   for /f "delims== tokens=1,2" %i in (.env) do set %i=%j
#
# To load on Windows (PowerShell):
#   Get-Content .env | ForEach-Object { $k,$v = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($k,$v) }
#
# To load on Linux / Mac:
#   export $(grep -v '^#' .env | xargs)
# ─────────────────────────────────────────────────────────────────────────────

# Base URL — host only, NO chat path suffix.
# Spring AI constructs the final URL as:  LLM_BASE_URL + LLM_COMPLETIONS_PATH
#
# CORRECT : LLM_BASE_URL=http://bank.llm
# WRONG   : LLM_BASE_URL=http://bank.llm/v1/openai/chat/completion  (path goes in LLM_COMPLETIONS_PATH)
LLM_BASE_URL=http://your-internal-llm-host:port

# Exact chat completions path on your internal LLM server.
# Spring AI appends this to LLM_BASE_URL — set it to your server's full path.
#
# Internal server example : /v1/openai/chat/completion
# Standard OpenAI default : /v1/chat/completions  (used if this var is not set)
LLM_COMPLETIONS_PATH=/v1/openai/chat/completion

# API key for the LLM endpoint.
# Set to "none" if the internal server does not require authentication.
LLM_API_KEY=your-api-key-here

# Model name as configured on the internal LLM server.
# Examples: llama3, mistral-7b, gpt-4o, qwen2
LLM_MODEL=gpt-4o

# (Optional) Corporate proxy URL with credentials.
# Format : http://username:password@proxyhost:port
# Example: http://john:secret@proxy.bank.local:8080
# Leave blank or remove this line entirely if no proxy is needed.
LLM_PROXY_URL=http://username:password@proxyhost:port
